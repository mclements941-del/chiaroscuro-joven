---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'posts'> };

const { entry } = Astro.props;
const { Content } = await render(entry);

const formatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="container container--reading post">
    <p class="section-label"><a href="/blog">← Blog</a></p>
    <header class="post-header">
      <time class="post-date" datetime={entry.data.pubDate.toISOString()}>
        {formatter.format(entry.data.pubDate)}
      </time>
      <h1>{entry.data.title}</h1>
    </header>
    <div class="prose post-body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .section-label a {
    color: var(--cj-whisper);
    text-decoration: none;
    letter-spacing: 0.25em;
  }

  .section-label a:hover {
    color: var(--cj-gold);
    text-decoration: none;
  }

  .post-header {
    margin-bottom: 48px;
  }

  .post-date {
    font-family: var(--cj-sans);
    font-size: 0.75rem;
    color: var(--cj-whisper);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 12px;
  }

  /* Post title lives outside .prose so it doesn't inherit the h1 size clamp —
     posts want a slightly smaller hero than the .prose default. */
  .post-header h1 {
    font-family: var(--cj-serif);
    font-weight: 600;
    color: var(--cj-pearl);
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: 0.02em;
  }

  /* Gold drop-cap on the first paragraph of the post body. Scoped here so
     other .prose containers (About, future gallery intros) don't inherit it. */
  .post-body :global(p:first-of-type::first-letter) {
    font-family: var(--cj-serif);
    font-size: 3.5rem;
    color: var(--cj-gold-bright);
    float: left;
    line-height: 0.9;
    padding-right: 8px;
    padding-top: 6px;
  }

  .post-body :global(p) {
    font-size: 1.05rem;
    color: var(--cj-cream);
  }
</style>
