---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog" description="Writing from Chiaroscuro Joven — weekly(ish) notes on art, ideas, and what inspires me.">
  <section class="container container--reading">
    <p class="section-label">Blog</p>
    <h1>Not quite ready</h1>
    <p class="placeholder">
      The first post is still being composed in the dark. Check back soon, or subscribe to the
      <a href="/rss.xml">RSS feed</a> to catch it when it lands.
    </p>
  </section>
</BaseLayout>

<style>
  .placeholder {
    color: var(--cj-muted);
    margin-top: 24px;
    font-size: 1.1rem;
  }
</style>
