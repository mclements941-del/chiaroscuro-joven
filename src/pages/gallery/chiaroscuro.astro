---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

const entry = await getEntry('gallery', 'chiaroscuro');
if (!entry) {
  throw new Error('Gallery entry "chiaroscuro" not found');
}
const { title, subtitle, description, paintings, sources } = entry.data;
---

<BaseLayout
  title={title}
  description={`${subtitle}. A curated gallery from Chiaroscuro Joven.`}
>
  <section class="hero">
    <h1>{title}</h1>
    <p class="subtitle">{subtitle}</p>
    <p class="definition" set:html={description}></p>
  </section>

  <div class="gallery">
    {paintings.map((p, i) => (
      <>
        {p.section && (
          <>
            {i > 0 && <div class="divider"></div>}
            <p class="section-label section-label--gallery">{p.section}</p>
          </>
        )}
        <div class="painting" style={`animation-delay: ${0.1 + i * 0.05}s`}>
          <div class="painting-number">{p.number}</div>
          <Image src={p.image} alt={p.alt} loading="lazy" />
          <div class="painting-info">
            <div class="painting-title">{p.title}</div>
            <div class="painting-meta">{p.meta}</div>
            <p class="painting-description">
              {p.description}
              {' '}
              <span class="chiaroscuro-note">{p.chiaroscuroNote}</span>
              {' '}
              {p.descriptionEnd}
            </p>
          </div>
        </div>
      </>
    ))}
  </div>

  {sources && sources.length > 0 && (
    <section class="sources">
      <p class="section-label">Sources</p>
      <p>
        {sources.map((source, i) => (
          <>
            {i > 0 && <> · </>}
            <a href={source.url} target="_blank" rel="noopener">{source.name}</a>
          </>
        ))}
      </p>
    </section>
  )}
</BaseLayout>

<style>
  .gallery {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .section-label--gallery {
    text-align: center;
    margin-bottom: 60px;
  }

  .painting {
    margin-bottom: 100px;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 0.8s ease forwards;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .painting-number {
    font-family: var(--cj-serif);
    font-size: 0.85rem;
    color: var(--cj-whisper);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .painting img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    display: block;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
    transition: box-shadow 0.4s ease;
  }

  .painting img:hover {
    box-shadow: 0 30px 80px rgba(180, 140, 80, 0.15), 0 20px 60px rgba(0, 0, 0, 0.6);
  }

  .painting-info {
    padding: 28px 0 0;
  }

  .painting-title {
    font-family: var(--cj-serif);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--cj-pearl);
    margin-bottom: 4px;
  }

  .painting-meta {
    font-size: 0.85rem;
    color: var(--cj-gold);
    margin-bottom: 16px;
  }

  .painting-description {
    font-size: 0.95rem;
    color: var(--cj-muted);
    max-width: 720px;
    line-height: 1.8;
  }

  .painting-description .chiaroscuro-note {
    color: var(--cj-gold-bright);
    font-weight: 400;
  }

  .divider {
    width: 60px;
    height: 1px;
    background: var(--cj-dim);
    margin: 0 auto 100px;
  }

  .sources {
    max-width: var(--cj-max-width);
    margin: 0 auto;
    padding: 60px 24px 80px;
    text-align: center;
    border-top: 1px solid var(--cj-ink);
  }

  .sources p:last-child {
    font-size: 0.85rem;
    color: var(--cj-quiet);
  }

  .sources a {
    color: var(--cj-gold);
  }

  .sources a:hover {
    color: var(--cj-gold-bright);
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .painting {
      margin-bottom: 70px;
    }
    .painting-title {
      font-size: 1.3rem;
    }
    .gallery {
      padding: 0 16px 60px;
    }
  }
</style>
