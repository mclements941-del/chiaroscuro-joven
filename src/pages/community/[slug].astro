---
// /community/[slug] — thread detail + flat reply list + reply form.
// Members-bucket route (middleware enforces forum_joined_at + not banned).
//
// Phase 5 additions:
//   - Thread actions bar: edit (own ≤10m), delete (own ≤10m OR admin), lock (admin)
//   - Per-reply actions: edit (own ≤10m), delete (own ≤10m OR admin)
//   - Admin viewing a deleted thread sees a "[removed]" banner; members
//     don't reach this page because RLS filters deleted threads out.

import BaseLayout from '../../layouts/BaseLayout.astro';
import { createSupabaseServerClient } from '../../lib/supabase/server';
import { renderMarkdown } from '../../lib/markdown';

const { slug } = Astro.params;
if (!slug) return new Response('Not Found', { status: 404 });

const supabase = createSupabaseServerClient(Astro.cookies);
const self = Astro.locals.user;
const selfProfile = Astro.locals.profile;
const isAdmin = !!selfProfile?.is_admin;
const selfId = self?.id ?? null;

// ──────────────────────────────────────────────────────────────────────────
// POST: submit a reply. Uses the thread's id (looked up from slug).
// Redirects to the same URL on success (post-redirect-get) so F5 doesn't
// re-submit and the render below picks up the new reply.
// ──────────────────────────────────────────────────────────────────────────
let replyError: string | null = null;

if (Astro.request.method === 'POST') {
  let form: FormData | null = null;
  try {
    form = await Astro.request.formData();
  } catch {
    replyError = 'Submission could not be parsed.';
  }
  if (form) {
    const body = String(form.get('body') ?? '').trim();
    if (!body) {
      replyError = 'Reply cannot be empty.';
    } else if (body.length > 10000) {
      replyError = 'Reply must be 10,000 characters or fewer.';
    } else {
      const { data: threadForReply } = await supabase
        .from('threads')
        .select('id, locked_at, deleted_at')
        .eq('slug', slug)
        .maybeSingle();

      if (!threadForReply) {
        return new Response('Thread not found', { status: 404 });
      }

      const { error } = await supabase.rpc('rpc_create_reply', {
        p_thread_id: threadForReply.id,
        p_body: body,
      });
      if (error) {
        if (/rate_limit_exceeded/.test(error.message)) {
          replyError = 'Posting too fast. Wait a moment.';
        } else if (/thread_unavailable/.test(error.message)) {
          replyError = 'This thread is locked or removed.';
        } else if (/forbidden/.test(error.message)) {
          replyError = "You can't post to this thread.";
        } else {
          replyError = 'Failed to post reply. Try again.';
          console.error('[thread] rpc_create_reply:', error.message);
        }
      } else {
        return Astro.redirect(`/community/${slug}`);
      }
    }
  }
}

// ──────────────────────────────────────────────────────────────────────────
// GET: load thread + replies, render markdown.
// ──────────────────────────────────────────────────────────────────────────

type ThreadRow = {
  id: string;
  slug: string;
  title: string;
  body: string;
  category_slug: string;
  author_id: string;
  created_at: string;
  reply_count: number;
  locked_at: string | null;
  deleted_at: string | null;
  author: { display_name: string } | null;
};

const { data: threadRaw } = await supabase
  .from('threads')
  .select(
    'id, slug, title, body, category_slug, author_id, created_at, reply_count, locked_at, deleted_at, author:author_id(display_name)',
  )
  .eq('slug', slug)
  .maybeSingle();

// Supabase FK expansion types default to array shape; FK is to-one so coerce.
const thread = threadRaw as unknown as ThreadRow | null;
if (!thread) {
  return new Response('Thread not found', { status: 404 });
}

type ReplyRow = {
  id: string;
  body: string;
  created_at: string;
  author_id: string;
  author: { display_name: string } | null;
};

const { data: replyData } = await supabase
  .from('replies')
  .select('id, body, created_at, author_id, author:author_id(display_name)')
  .eq('thread_id', thread.id)
  .is('deleted_at', null)
  .order('created_at', { ascending: true });

const TEN_MIN_MS = 10 * 60 * 1000;

function withinEditWindow(isoCreated: string): boolean {
  return new Date(isoCreated).getTime() > Date.now() - TEN_MIN_MS;
}

// Per-reply flags (computed once, embedded in the render).
type ReplyWithActions = ReplyRow & {
  bodyHtml: string;
  canEdit: boolean;
  canDelete: boolean;
};

const threadLockedOrDeleted = !!thread.locked_at || !!thread.deleted_at;

const replies: ReplyWithActions[] = (
  (replyData ?? []) as unknown as ReplyRow[]
).map((r) => {
  const ownedByMe = !!selfId && r.author_id === selfId;
  const inWindow = withinEditWindow(r.created_at);
  return {
    ...r,
    bodyHtml: renderMarkdown(r.body),
    canEdit: ownedByMe && inWindow && !threadLockedOrDeleted,
    canDelete:
      (ownedByMe && inWindow && !threadLockedOrDeleted) || isAdmin,
  };
});

const threadBodyHtml = renderMarkdown(thread.body);
const dateFmt = new Intl.DateTimeFormat('en-US', { dateStyle: 'medium' });

// Thread-level action flags.
const threadOwnedByMe = !!selfId && thread.author_id === selfId;
const threadInWindow = withinEditWindow(thread.created_at);
const canEditThread =
  threadOwnedByMe && threadInWindow && !thread.locked_at && !thread.deleted_at;
const canDeleteThread =
  (threadOwnedByMe && threadInWindow && !thread.deleted_at) ||
  (isAdmin && !thread.deleted_at);
const canLockThread = isAdmin && !thread.locked_at && !thread.deleted_at;
---
<BaseLayout title={thread.title} description="A thread on Chiaroscuro Joven.">
  <article class="container container--reading thread">
    <p class="section-label"><a href="/community">← Community</a></p>
    <h1>{thread.title}</h1>
    <div class="meta">
      <span>{thread.author?.display_name ?? 'member'}</span>
      <span aria-hidden="true">·</span>
      <span>{dateFmt.format(new Date(thread.created_at))}</span>
      <span aria-hidden="true">·</span>
      <span>{thread.category_slug}</span>
      {thread.locked_at && (
        <>
          <span aria-hidden="true">·</span>
          <span class="locked">locked</span>
        </>
      )}
      {thread.deleted_at && (
        <>
          <span aria-hidden="true">·</span>
          <span class="removed">removed</span>
        </>
      )}
    </div>

    {thread.deleted_at && (
      <p class="removed-banner">
        This thread has been removed. You're seeing it because you're an admin.
      </p>
    )}

    {(canEditThread || canDeleteThread || canLockThread) && (
      <div class="thread-actions">
        {canEditThread && (
          <a class="action-link" href={`/community/${slug}/edit`}>Edit</a>
        )}
        {canLockThread && (
          <form method="post" action={`/community/${slug}/lock`} class="inline-form">
            <button type="submit" class="action-btn">Lock</button>
          </form>
        )}
        {canDeleteThread && (
          <form
            method="post"
            action={`/community/${slug}/delete`}
            class="inline-form"
            onsubmit="return confirm('Delete this thread?')"
          >
            <button type="submit" class="action-btn action-btn--danger">Delete</button>
          </form>
        )}
      </div>
    )}

    <div class="body prose" set:html={threadBodyHtml}></div>

    <section class="replies">
      <h2>
        {thread.reply_count} {thread.reply_count === 1 ? 'reply' : 'replies'}
      </h2>
      {replies.map((r) => (
        <article class="reply" id={`reply-${r.id}`}>
          <div class="meta">
            <span>{r.author?.display_name ?? 'member'}</span>
            <span aria-hidden="true">·</span>
            <span>{dateFmt.format(new Date(r.created_at))}</span>
            {(r.canEdit || r.canDelete) && (
              <>
                <span aria-hidden="true">·</span>
                <span class="reply-actions">
                  {r.canEdit && (
                    <a class="action-link-sm" href={`/community/reply/${r.id}/edit`}>edit</a>
                  )}
                  {r.canDelete && (
                    <form
                      method="post"
                      action={`/community/reply/${r.id}/delete`}
                      class="inline-form"
                      onsubmit="return confirm('Delete this reply?')"
                    >
                      <button type="submit" class="action-link-sm action-link-sm--danger">delete</button>
                    </form>
                  )}
                </span>
              </>
            )}
          </div>
          <div class="body prose" set:html={r.bodyHtml}></div>
        </article>
      ))}
    </section>

    {!thread.locked_at && !thread.deleted_at ? (
      <section class="reply-form">
        <h2>Reply</h2>
        {replyError && <p class="form-error">{replyError}</p>}
        <form method="post" action={`/community/${slug}`}>
          <label for="body">Markdown <span class="hint">(up to 10,000 chars)</span></label>
          <textarea id="body" name="body" required maxlength="10000" rows="6"></textarea>
          <button type="submit">Post reply</button>
        </form>
      </section>
    ) : thread.locked_at && !thread.deleted_at ? (
      <p class="locked-note">This thread is locked. No new replies.</p>
    ) : null}
  </article>
</BaseLayout>

<style>
  .thread h1 {
    font-family: var(--cj-serif);
    font-weight: 600;
    color: var(--cj-pearl);
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: 0.02em;
    margin: 0 0 12px;
  }
  .meta {
    display: flex;
    gap: 10px;
    font-family: var(--cj-sans);
    font-size: 0.8rem;
    color: var(--cj-quiet);
    flex-wrap: wrap;
    margin-bottom: 16px;
    align-items: center;
  }
  .meta .locked { color: var(--cj-gold); }
  .meta .removed { color: #b85050; }

  .removed-banner {
    padding: 10px 16px;
    margin: 0 0 16px;
    font-size: 0.9rem;
    color: var(--cj-pearl);
    border-left: 2px solid #b85050;
    font-family: var(--cj-sans);
  }

  .thread-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 8px 0;
    margin-bottom: 24px;
    border-top: 1px solid var(--cj-shadow);
    border-bottom: 1px solid var(--cj-shadow);
  }
  .inline-form { display: inline; margin: 0; }
  .action-link, .action-btn {
    font-family: var(--cj-sans);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cj-whisper);
    text-decoration: none;
    background: transparent;
    border: 1px solid var(--cj-shadow);
    padding: 4px 10px;
    cursor: pointer;
    border-radius: 2px;
  }
  .action-link:hover, .action-btn:hover {
    color: var(--cj-gold);
    border-color: var(--cj-gold);
  }
  .action-btn--danger { color: #b85050; border-color: #b85050; }
  .action-btn--danger:hover {
    background: #b85050;
    color: var(--cj-pearl);
    border-color: #b85050;
  }

  .reply-actions {
    display: inline-flex;
    gap: 10px;
    align-items: center;
  }
  .action-link-sm {
    font-family: var(--cj-sans);
    font-size: 0.75rem;
    color: var(--cj-whisper);
    text-decoration: none;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    letter-spacing: 0.02em;
  }
  .action-link-sm:hover { color: var(--cj-gold); }
  .action-link-sm--danger { color: #b85050; }
  .action-link-sm--danger:hover { color: #e47070; }

  .body.prose { margin-bottom: 48px; }
  .body.prose :global(p) {
    font-size: 1.05rem;
    color: var(--cj-cream);
  }
  .body.prose :global(a) {
    color: var(--cj-gold-bright);
    text-decoration: underline;
    text-decoration-color: var(--cj-shadow);
  }
  .body.prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: rgba(255, 255, 255, 0.05);
    padding: 2px 6px;
    border-radius: 2px;
  }
  .body.prose :global(pre) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.85em;
    background: rgba(0, 0, 0, 0.3);
    padding: 12px 16px;
    overflow-x: auto;
    border-radius: 2px;
  }
  .body.prose :global(blockquote) {
    border-left: 2px solid var(--cj-shadow);
    padding-left: 16px;
    color: var(--cj-muted);
    margin: 16px 0;
  }

  .replies h2 {
    font-family: var(--cj-sans);
    font-size: 0.8rem;
    color: var(--cj-whisper);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 48px 0 24px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--cj-shadow);
  }
  .reply {
    padding: 24px 0;
    border-bottom: 1px solid var(--cj-shadow);
  }
  .reply:last-of-type { border-bottom: none; }
  .reply:target {
    background: rgba(184, 168, 138, 0.05);
    padding-left: 12px;
    padding-right: 12px;
    margin-left: -12px;
    margin-right: -12px;
  }

  .reply-form {
    margin-top: 48px;
  }
  .reply-form h2 {
    font-family: var(--cj-sans);
    font-size: 0.8rem;
    color: var(--cj-whisper);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 400;
    margin-bottom: 16px;
  }
  .reply-form form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .reply-form label {
    font-family: var(--cj-sans);
    font-size: 0.75rem;
    color: var(--cj-whisper);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .hint {
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: 0.7rem;
    color: var(--cj-quiet);
  }
  .reply-form textarea {
    font-family: var(--cj-sans);
    font-size: 0.95rem;
    background: transparent;
    border: 1px solid var(--cj-shadow);
    color: var(--cj-pearl);
    padding: 12px 14px;
    border-radius: 2px;
    resize: vertical;
  }
  .reply-form textarea:focus { outline: none; border-color: var(--cj-gold); }
  .reply-form button {
    font-family: var(--cj-sans);
    font-size: 0.85rem;
    background: var(--cj-gold);
    color: var(--cj-ink);
    padding: 12px 18px;
    border: none;
    cursor: pointer;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-radius: 2px;
    align-self: start;
  }
  .reply-form button:hover { background: var(--cj-gold-bright); }
  .form-error {
    color: var(--cj-pearl);
    border-left: 2px solid #b85050;
    padding: 8px 16px;
    margin: 0 0 16px;
    font-size: 0.95rem;
  }
  .locked-note {
    font-family: var(--cj-sans);
    color: var(--cj-muted);
    font-style: italic;
    margin-top: 48px;
    padding: 16px 0;
    border-top: 1px solid var(--cj-shadow);
  }

  .section-label a {
    color: var(--cj-whisper);
    text-decoration: none;
    letter-spacing: 0.25em;
  }
  .section-label a:hover { color: var(--cj-gold); }
</style>
