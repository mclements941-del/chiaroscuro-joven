---
// Phase 1 login page. GET renders the form; POST is stubbed until Phase 3
// implements the rate-limit-checked magic-link flow.
//
// For Phase 1 end-to-end testing, issue invites via the Supabase dashboard
// or a scratch Node script calling auth.admin.inviteUserByEmail — that
// delivers the email which hits /auth/confirm → POST /auth/callback.

import BaseLayout from '../../layouts/BaseLayout.astro';

const url = new URL(Astro.request.url);
const reason = url.searchParams.get('reason');
const reasonNotice =
  reason === 'not_member'
    ? "That sign-in link isn't associated with an active membership."
    : reason === 'account_closed'
    ? 'This account is no longer active.'
    : null;

if (Astro.request.method === 'POST') {
  return new Response(
    'Login POST is scheduled for Phase 3. Use admin invite for Phase 1 testing.',
    { status: 501, headers: { 'content-type': 'text/plain' } },
  );
}
---
<BaseLayout title="Sign in" description="Sign in to Chiaroscuro Joven.">
  <section class="container container--reading">
    <p class="section-label">Community</p>
    <h1>Sign in</h1>
    {reasonNotice && <p class="notice">{reasonNotice}</p>}
    <p class="intro">
      Enter your email. If your account is eligible, a sign-in link will arrive shortly.
    </p>
    <form method="post" action="/community/login">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" required autocomplete="email" />
      <button type="submit">Send sign-in link</button>
    </form>
  </section>
</BaseLayout>

<style>
  h1 {
    font-family: var(--cj-serif);
    font-weight: 600;
    color: var(--cj-pearl);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: 0.04em;
  }
  .intro { color: var(--cj-muted); margin: 16px 0 24px; }
  .notice {
    color: var(--cj-whisper);
    border-left: 2px solid var(--cj-shadow);
    padding: 8px 16px;
    margin: 16px 0;
    font-size: 0.95rem;
  }
  form {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
  }
  label {
    font-family: var(--cj-sans);
    font-size: 0.75rem;
    color: var(--cj-whisper);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  input {
    font-family: var(--cj-serif);
    font-size: 1.1rem;
    background: transparent;
    border: 1px solid var(--cj-shadow);
    color: var(--cj-pearl);
    padding: 12px 14px;
    border-radius: 2px;
  }
  input:focus { outline: none; border-color: var(--cj-gold); }
  button {
    font-family: var(--cj-sans);
    font-size: 0.85rem;
    background: var(--cj-gold);
    color: var(--cj-ink);
    padding: 12px 18px;
    border: none;
    cursor: pointer;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-radius: 2px;
  }
  button:hover { background: var(--cj-gold-bright); }
</style>
