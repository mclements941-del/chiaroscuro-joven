---
// IMPL-0003 D29: this route is flag-dependent-gated by middleware.
// FORUM_ENABLED=false → placeholder (this file's current content).
// FORUM_ENABLED=true → thread list (Phase 4 will replace this body).
// Removed `prerender = true` because middleware does not run on
// prerendered routes, and the flag-dependent bucket classification
// requires middleware to execute per request.
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Community" description="Chiaroscuro Joven's community space — opening soon.">
  <section class="container container--reading">
    <p class="section-label">Community</p>
    <h1>Opening soon</h1>
    <p class="placeholder">
      A space to think alongside others — threaded discussions on art, literature, film, and
      whatever else catches the light. Built piece by piece, without haste.
    </p>
    <p class="placeholder">
      When the doors open, signup will be an email magic link. No passwords, no tracking, no
      algorithmic feed.
    </p>
  </section>
</BaseLayout>

<style>
  h1 {
    font-family: var(--cj-serif);
    font-weight: 600;
    color: var(--cj-pearl);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: 0.04em;
  }

  .placeholder {
    color: var(--cj-muted);
    margin-top: 20px;
    font-size: 1.05rem;
  }
</style>
