---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Community" description="Chiaroscuro Joven's community space — opening soon.">
  <section class="container container--reading">
    <p class="section-label">Community</p>
    <h1>Opening soon</h1>
    <p class="placeholder">
      A space to think alongside others — threaded discussions on art, literature, film, and
      whatever else catches the light. Being built deliberately, piece by piece. Per
      IMPL-0001 §5.6-§5.13 if you're into that kind of thing.
    </p>
    <p class="placeholder">
      When the doors open, signup will be an email magic link — no passwords to forget.
    </p>
  </section>
</BaseLayout>

<style>
  .placeholder {
    color: var(--cj-muted);
    margin-top: 20px;
    font-size: 1.05rem;
  }
</style>
