---
// IMPL-0003 §4 + D36: email-prefetch interstitial.
// GET is a pure render — no verifyOtp, no DB calls, no cookies, no mutation.
// Mail-security scanners (Outlook Safe Links, Google URL scanners, etc.)
// can prefetch this URL without consuming the token. The POST to
// /community/auth/callback is the only consuming path.
//
// D42 response headers: no-store, same-origin referrer, noindex.
// Asset discipline: NO third-party assets on this page. Styles inlined,
// no remote fonts, no analytics. A future layout or analytics addition
// that loads a third-party origin could leak token_hash via Referer.
//
// Referrer-Policy rationale: `same-origin` (not `no-referrer`). Per Fetch
// spec, `no-referrer` sets request.origin = null on outgoing requests,
// which turns the callback POST's Origin header into literal "null" and
// fails our middleware's Origin allowlist. `same-origin` preserves
// Referer+Origin for same-origin requests (our POST to /callback is safe
// — token_hash is already in the request body, so logging Referer adds
// no new info) while still suppressing Referer cross-origin. Combined
// with the "no third-party assets" invariant, there's no leakage surface.

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, private');
Astro.response.headers.set('Referrer-Policy', 'same-origin');
Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow');

// Tight CSP: promotes the no-third-party-asset invariant from convention to
// enforceable. default-src 'none' blocks fonts/scripts/images/connects;
// style-src 'unsafe-inline' permits the inline <style> block above;
// form-action 'self' prevents a compromised script (there shouldn't be any,
// but defense-in-depth) from POSTing the token_hash elsewhere; base-uri
// 'none' blocks <base> injection; frame-ancestors 'none' prevents
// clickjacking. If any of these start to break the page, the page itself
// is the thing that needs to change — not this header.
Astro.response.headers.set(
  'Content-Security-Policy',
  "default-src 'none'; style-src 'unsafe-inline'; form-action 'self'; base-uri 'none'; frame-ancestors 'none'",
);

const token_hash = Astro.url.searchParams.get('token_hash') ?? '';
const type = Astro.url.searchParams.get('type') ?? '';

const ctaText =
  type === 'invite' ? 'Accept invite' :
  type === 'email' || type === 'magiclink' ? 'Sign in' :
  'Continue';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Confirm sign-in — Chiaroscuro Joven</title>
    <meta name="robots" content="noindex, nofollow" />
    <style>
      /* Inlined styles. Zero third-party assets per IMPL-0003 D42. */
      :root {
        --ink: #0a0a0a;
        --pearl: #e8e0d4;
        --muted: #a89b85;
        --gold: #b8a88a;
        --gold-bright: #d4c4a8;
        --shadow: #2a2a2a;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        background: var(--ink);
        color: var(--pearl);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px;
      }
      main { max-width: 440px; text-align: center; }
      .brand {
        font-size: 0.75rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--muted);
        margin: 0 0 48px;
      }
      h1 {
        font-weight: 600;
        letter-spacing: 0.04em;
        font-size: 2rem;
        margin: 0 0 16px;
      }
      p {
        color: var(--muted);
        margin: 0 0 32px;
        font-size: 0.95rem;
        line-height: 1.5;
      }
      button {
        font-size: 0.85rem;
        font-family: inherit;
        background: var(--gold);
        color: var(--ink);
        padding: 14px 28px;
        border: none;
        cursor: pointer;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        border-radius: 2px;
      }
      button:hover { background: var(--gold-bright); }
      button:focus { outline: 2px solid var(--gold-bright); outline-offset: 2px; }
    </style>
  </head>
  <body>
    <main>
      <p class="brand">Chiaroscuro Joven</p>
      <h1>Confirm sign-in</h1>
      <p>Click below to complete sign-in. This one-time link is valid for about an hour.</p>
      <form method="post" action="/community/auth/callback">
        <input type="hidden" name="token_hash" value={token_hash} />
        <input type="hidden" name="type" value={type} />
        <button type="submit">{ctaText}</button>
      </form>
    </main>
  </body>
</html>
